# Keep third-party credentials server-side in production.
# The frontend calls the local/backend proxy:
#   GET /api/worldcup/snapshot
#   GET /api/worldcup/fixtures
#   GET /api/worldcup/groups
#   GET /api/worldcup/standings
#   GET /api/worldcup/odds/:fixtureId
#
# No key is required for the public OpenFootball schedule fallback.
# API-Football adds live sync and licensed odds:
# API_FOOTBALL_KEY=your_api_football_key
# APISPORTS_KEY=alternative_env_name_for_the_same_key
